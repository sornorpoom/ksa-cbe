const DOCUMENT_ID = '1FfY4IoxwDv37dL9-k7PwJu81pEuPJWXAVOpXE-Oib3w';

function doGet() {
  return HtmlService
    .createTemplateFromFile('index')
    .evaluate()
    .setTitle('KSA Competency Explorer (CBE)')
    .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL);
}

function getAppData(forceRefresh) {
  try {
    const doc = DocumentApp.openById(DOCUMENT_ID);
    const parsed = parseDocument_(doc);
    parsed.source = {
      type: 'google_doc',
      documentId: DOCUMENT_ID,
      title: doc.getName(),
      refreshedAt: new Date().toISOString(),
      live: true
    };
    return parsed;
  } catch (error) {
    const fallback = getFallbackData_();
    fallback.source = {
      type: 'fallback',
      documentId: DOCUMENT_ID,
      title: fallback.title || 'การวิเคราะห์ KSA จำแนกตามสมรรถนะ 6 ด้าน',
      refreshedAt: new Date().toISOString(),
      live: false,
      message: 'ยังอ่าน Google Doc แบบสดไม่ได้ โปรดตรวจสอบสิทธิ์การเข้าถึงเอกสารและ authorize Apps Script'
    };
    fallback.error = String(error && error.message ? error.message : error);
    return fallback;
  }
}

function parseDocument_(doc) {
  const body = doc.getBody();
  const numElements = body.getNumChildren();
  
  const data = {
    title: "การวิเคราะห์ KSA จำแนกตามสมรรถนะ 6 ด้าน",
    levels: []
  };

  let currentLevel = null;
  let currentCompetency = null;
  let currentGroup = null;
  let currentItem = null;

  for (let i = 0; i < numElements; i++) {
    const el = body.getChild(i);
    const type = el.getType();
    
    // We only process paragraphs and list items
    if (type !== DocumentApp.ElementType.PARAGRAPH && type !== DocumentApp.ElementType.LIST_ITEM) {
      continue;
    }
    
    const text = el.getText().trim();
    if (!text) continue;
    
    // Skip document header metadata and separator lines
    if (/Title:|Description:|Source:|---|___/i.test(text) || /^[_-\s\u00a0]+$/.test(text)) continue;

    // Detect level: "ระดับชั้นประถมศึกษา" or "ระดับชั้นมัธยมศึกษา" (Exact match after space removal)
    const cleanedText = text.replace(/[\s\u00a0]+/g, ""); // Remove all spaces and non-breaking spaces
    if (cleanedText === "ระดับชั้นประถมศึกษา" || cleanedText === "ระดับประถมศึกษา") {
      currentLevel = {
        name: "ระดับชั้นประถมศึกษา",
        competencies: []
      };
      data.levels.push(currentLevel);
      currentCompetency = null;
      currentGroup = null;
      currentItem = null;
      continue;
    }
    if (cleanedText === "ระดับชั้นมัธยมศึกษา" || cleanedText === "ระดับมัธยมศึกษา") {
      currentLevel = {
        name: "ระดับชั้นมัธยมศึกษา",
        competencies: []
      };
      data.levels.push(currentLevel);
      currentCompetency = null;
      currentGroup = null;
      currentItem = null;
      continue;
    }

    if (!currentLevel) continue;

    // Detect competency headings. Some primary-level source docs omit the leading
    // number, while secondary headings usually use "1. สมรรถนะ...".
    const compMatch = text.match(/^(?:\d+\.\s*)?(สมรรถนะ.+)$/);
    if (compMatch) {
      const compName = compMatch[1].trim();
      
      // Generate ID from English abbreviation in name
      let id = "comp-" + (data.levels.length) + "-" + (currentLevel.competencies.length + 1);
      const abbrMatch = compName.match(/\(([^)]+)\)/);
      if (abbrMatch) {
        const abbr = abbrMatch[1];
        const colonMatch = abbr.match(/:\s*([A-Za-z]+)/);
        if (colonMatch) {
          id = colonMatch[1].toLowerCase();
        } else if (/^[A-Za-z\s]+$/.test(abbr)) {
          id = abbr.replace(/\s+/g, '-').toLowerCase();
        }
      }

      currentCompetency = {
        id: id,
        name: compName,
        groups: []
      };
      currentLevel.competencies.push(currentCompetency);
      currentGroup = null;
      currentItem = null;
      continue;
    }

    if (!currentCompetency) continue;

    // Detect Group: accepts both "ด้านทักษะ..." and numbered headings like
    // "2. ด้านทักษะ (Skills) ที่ระบุในเล่ม".
    const isListItem = (type === DocumentApp.ElementType.LIST_ITEM);
    const isGroupHeader = /^(?:\d+\.\s*)?ด้าน\s*(ความรู้|ทักษะ|เจตคติ)/.test(text) ||
      (text.indexOf("ด้าน") > -1 && /Knowledge|Skills|Attitudes|ความรู้|ทักษะ|เจตคติ/i.test(text) && !/^\d+\.\d+/.test(text));
    
    if (isGroupHeader) {
      let label = "Knowledge";
      let title = "ด้านความรู้ (Knowledge)";
      
      if (/ทักษะ|Skills/i.test(text)) {
        label = "Skills";
        title = "ด้านทักษะ (Skills)";
      } else if (/เจตคติ|Attitudes/i.test(text)) {
        label = "Attitudes";
        title = "ด้านเจตคติและคุณลักษณะ (Attitudes / Attributes)";
      }

      const emoji = label === "Knowledge" ? "📘 " : (label === "Skills" ? "🛠️ " : "❤️ ");

      currentGroup = {
        label: label,
        title: emoji + title,
        intro: "",
        items: []
      };
      currentCompetency.groups.push(currentGroup);
      currentItem = null;
      continue;
    }

    if (!currentGroup) continue;

    // Determine its nesting level if it is a list item
    const nestingLevel = isListItem ? el.asListItem().getNestingLevel() : -1;

    // Check if it's a numbered main item (starts with 1.1, 2.1, etc.)
    const numberMatch = text.match(/^(\d+\.\d+)\s*(.*)$/);
    
    // We treat it as a main item if:
    // 1. It matches the number pattern (e.g. "1.1 ...")
    // 2. Or it is a list item at nesting level 0 (parent level of a list)
    const isMainItem = numberMatch || (isListItem && nestingLevel === 0);
    
    if (isMainItem) {
      let title = text;
      let detail = "";
      
      if (numberMatch) {
        const rest = numberMatch[2].trim();
        const colonMatch = rest.match(/^([^:：]+)[:：]\s*(.*)$/);
        if (colonMatch) {
          title = numberMatch[1] + " " + colonMatch[1].trim();
          detail = colonMatch[2].trim();
        } else {
          title = text;
        }
      } else {
        // List item at nesting level 0 without literal number prefix (auto-numbered list item in Google Docs)
        const colonMatch = text.match(/^([^:：]+)[:：]\s*(.*)$/);
        let rawTitle = text;
        if (colonMatch) {
          rawTitle = colonMatch[1].trim();
          detail = colonMatch[2].trim();
        }
        
        // Auto-generate the correct number prefix (e.g. 1.1, 2.1, 3.1)
        const groupNum = currentGroup.label === "Knowledge" ? 1 : (currentGroup.label === "Skills" ? 2 : 3);
        const itemIndex = currentGroup.items.length + 1;
        title = groupNum + "." + itemIndex + " " + rawTitle;
      }
      
      currentItem = {
        title: title,
        detail: detail,
        subitems: []
      };
      currentGroup.items.push(currentItem);
    } else if (isListItem && nestingLevel >= 1 && currentItem) {
      // Bullet point is a sub-item of the active main item
      currentItem.subitems.push(text);
    } else {
      // Group intro or paragraph detail extension
      if (currentGroup.items.length === 0) {
        currentGroup.intro = (currentGroup.intro + " " + text).trim();
      } else {
        const lastItem = currentGroup.items[currentGroup.items.length - 1];
        if (lastItem) {
          lastItem.detail = (lastItem.detail + " " + text).trim();
        }
      }
    }
  }

  return data;
}

